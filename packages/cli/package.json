{
  "name": "ariadne-cli",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "ariadne": "dist/index.js"
  },
  "files": ["dist", "hooks"],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun && cp -r src/hooks hooks && cp ../core/src/scip/scip.proto dist/scip.proto",
    "compile": "bun build src/index.ts --compile --outfile dist/ariadne",
    "test": "vitest run"
  },
  "devDependencies": {
    "ariadne-core": "workspace:*",
    "bun-types": "latest"
  }
}
